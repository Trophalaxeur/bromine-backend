# Deployed to /etc/bromine.env on the bromine LXC by the bromine-agent Ansible
# role (see gallium-homelab/ansible/roles/bromine-agent/templates/bromine-env.j2).
# This file documents the shape only — the real values live in Ansible Vault.

NODE_ENV=production
PORT=3000
# Prod runs behind Caddy (TLS on :443 → reverse_proxy → here), so the app binds
# loopback only — a LAN client can't reach :3000 directly and bypass TLS.
# Defaults to 127.0.0.1 when unset.
BIND_HOST=127.0.0.1

USE_CLAUDE_CLI=false
ANTHROPIC_API_KEY=

CARBON_NOTES_REPO_PATH=/home/bromineuser/repos/carbon-notes
BISMUTH_BLOG_REPO_PATH=/home/bromineuser/repos/bismuth-blog

CONTENT_TOKEN=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAILS=

BROMINE_ADMIN_EMAIL=admin@flefevre.fr
