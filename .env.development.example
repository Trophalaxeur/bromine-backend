# Copy to .env.development and fill in local paths.
# Loaded only when NODE_ENV=development (the default for `npm run dev`).

NODE_ENV=development
PORT=3000

# LLM: use the local Claude Code CLI (no separate API key needed in dev).
# Set to "false" to use ANTHROPIC_API_KEY instead, even in dev.
USE_CLAUDE_CLI=true
# Only needed if USE_CLAUDE_CLI=false:
# ANTHROPIC_API_KEY=

# Local checkouts — read directly from disk, no git clone/pull.
LOCAL_CARBON_NOTES=/home/flefevre/Project/perso/carbon-notes
LOCAL_BISMUTH_BLOG=/home/flefevre/Project/perso/bismuth-blog

# CONTENT_TOKEN is still required in dev: when the local bismuth-blog's
# `astro dev` starts, ALL its content loaders run (articles, docs — not just
# the CV), and those still fetch from GitHub unless bismuth-blog itself also
# has LOCAL_CARBON_NOTES set for its own dev server.
CONTENT_TOKEN=

# Google OAuth — same project as production, used to validate id_tokens.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAILS=me@flefevre.fr
